#!/usr/bin/env ruby
# encode64 "<str>"
# echo "str" | encode64
#
# $ echo "blah blah stdin" | encode64
# YmxhaCBibGFoIHN0ZGluCg==
#
# $ encode64 "blah blah ARGV"
# YmxhaCBibGFoIEFSR1Y=
#
# $ echo "blah blah stdin" | encode64 | decode64
# blah blah stdin
#
# $ decode64 $(encode64 "blah blah ARGV")
# blah blah ARGV

#
# note, you can do this on OSX (and probably linux) with
# echo <str> | base64
#
# I'm doing this here anyway, mostly to remind myself how to do it in ruby
require "base64"

# puts "stdin is a tty? #{$stdin.tty?.inspect}"

text = $stdin.tty? ? ARGV.join(' ') : $stdin.read

puts Base64.encode64(text)
