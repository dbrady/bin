#!/bin/bash
# rvm-install-with-openssl-3.0 <version> - install ruby with openssl 3.0. Apple
# Silicon needs this for rubies that need openssl 1 and can't link against
# openssl 2. As of 2025-07-23, that's ruby 3 up through 3.3.6 at least.
VERSION=$1
OPENSSL_DIR=$(brew --prefix openssl@3.0)

echo -e "\033[36mrvm install $VERSION --with-openssl-dir=$OPENSSL_DIR $@\033[0m"
rvm install $VERSION --with-openssl-dir=$OPENSSL_DIR $@
